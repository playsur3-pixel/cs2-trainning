import { getStore } from "@netlify/blobs";
import crypto from "node:crypto";

type AuthPlayerRecord = {
  pseudo: string;
  password_hash: string;
  updated_at?: string;
};

type LoginBody = {
  pseudo?: string;
  password?: string;
};

type SessionPayload = {
  pseudo: string;
  exp: number;
};

const authStore = getStore("auth-player");

function json(data: unknown, status = 200) {
  return new Response(JSON.stringify(data), {
    status,
    headers: {
      "content-type": "application/json; charset=utf-8",
    },
  });
}

function normalizePseudo(value: string) {
  return value.trim();
}

function sha256Hex(value: string) {
  return crypto.createHash("sha256").update(value, "utf8").digest("hex");
}

function base64UrlEncode(input: string) {
  return Buffer.from(input, "utf8").toString("base64url");
}

function base64UrlDecode(input: string) {
  return Buffer.from(input, "base64url").toString("utf8");
}

function signSession(payload: SessionPayload, secret: string) {
  const encodedPayload = base64UrlEncode(JSON.stringify(payload));

  const signature = crypto
    .createHmac("sha256", secret)
    .update(encodedPayload, "utf8")
    .digest("base64url");

  return `${encodedPayload}.${signature}`;
}

function safeEqualHex(a: string, b: string) {
  const aBuf = Buffer.from(a, "hex");
  const bBuf = Buffer.from(b, "hex");

  if (aBuf.length !== bBuf.length) return false;

  return crypto.timingSafeEqual(aBuf, bBuf);
}

export default async (req: Request) => {
  try {
    if (req.method !== "POST") {
      return json({ ok: false, message: "Méthode non autorisée." }, 405);
    }

    const secret = process.env.KPM_JWT_SECRET;

    if (!secret) {
      return json(
        { ok: false, message: "Variable KPM_JWT_SECRET manquante." },
        500
      );
    }

    let body: LoginBody;

    try {
      body = (await req.json()) as LoginBody;
    } catch {
      return json({ ok: false, message: "Body JSON invalide." }, 400);
    }

    const pseudo = normalizePseudo(body.pseudo ?? "");
    const password = body.password ?? "";

    if (!pseudo || !password) {
      return json(
        { ok: false, message: "Pseudo et mot de passe requis." },
        400
      );
    }

    const blobKey = `auth:${pseudo}`;
    const player = (await authStore.get(blobKey, {
    type: "json",
    })) as AuthPlayerRecord | null;

    if (!player) {
      return json({ ok: false, message: "Identifiants invalides." }, 401);
    }

    if (!player.password_hash || !player.pseudo) {
      return json(
        { ok: false, message: "Compte invalide dans le store." },
        500
      );
    }

    const incomingHash = sha256Hex(password);

    const passwordOk = safeEqualHex(incomingHash, player.password_hash);

    if (!passwordOk) {
      return json({ ok: false, message: "Identifiants invalides." }, 401);
    }

    const now = Math.floor(Date.now() / 1000);
    const sevenDays = 7 * 24 * 60 * 60;

    const payload: SessionPayload = {
      pseudo: player.pseudo,
      exp: now + sevenDays,
    };

    const token = signSession(payload, secret);

    return json({
      ok: true,
      token,
      pseudo: player.pseudo,
      message: "Connexion réussie.",
    });
  } catch (error) {
    console.error("kpm-login error:", error);
    return json({ ok: false, message: "Erreur serveur." }, 500);
  }
};